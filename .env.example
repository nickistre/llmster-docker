# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# =============================================================================
# Ports
# =============================================================================

# Host port for the LM Studio API
LLMSTER_PORT=1234

# Host port for Caddy HTTPS endpoint
CADDY_HTTPS_PORT=1243

# =============================================================================
# Container startup behaviour
# =============================================================================

# Set to 1 to re-download LM Studio on every container start.
LM_STUDIO_UPDATE=0

# Set to 1 to run `lms runtime update` on every container start.
LMS_RUNTIME_UPDATE=0

# JIT model TTL — seconds an idle JIT-loaded model stays in memory (default: 3600)
JIT_TTL_SECONDS=3600

# Unload previous JIT model when a new one loads (default: false — keep previous model in memory)
UNLOAD_PREVIOUS_MODEL=false

# =============================================================================
# GPU backend
# =============================================================================

# Set to 0 to build without ROCm runtime libraries (saves ~2-3 GB image size;
# use if you only need the Vulkan backend or have no AMD GPU).
INSTALL_ROCM=1

# AMD ROCm apt release to install. Change only to pick up a newer ROCm version.
ROCM_VERSION=6.4

# Use a pooled GPU allocator instead of raw hipMalloc/hipFree per operation.
# Reduces per-token memory churn on the ROCm backend and prevents GPU memory
# spikes from starving the display compositor (amdgpu pin failed -12 errors).
GGML_HIP_MEM_POOL=1

# =============================================================================
# ROCm diagnostics (uncomment only to diagnose crashes, then remove)
# =============================================================================

# Verbose HIP runtime logging. Produces a lot of output. 0=off, 3=verbose.
#AMD_LOG_LEVEL=3

# Synchronous HIP kernel launches — failing kernel appears in crash backtraces.
#HIP_LAUNCH_BLOCKING=1

# =============================================================================
# HTTPS / Caddy
# =============================================================================

# Hostname Caddy will serve (must be in a Cloudflare-managed zone)
PROXY_HOST=

# Cloudflare API token — needs Zone:Read + DNS:Edit for the domain
# Create one at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Email used for Let's Encrypt account registration
ACME_EMAIL=

# =============================================================================
# API Authentication
# =============================================================================

# Bearer token clients must send in the Authorization header:
#   Authorization: Bearer <LLM_API_KEY>
# Generate a strong random value, e.g.:
#   openssl rand -hex 32
LLM_API_KEY=
