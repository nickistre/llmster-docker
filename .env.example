# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# =============================================================================
# Container startup behaviour
# =============================================================================

# Set to 1 to re-download LM Studio on every container start.
LM_STUDIO_UPDATE=0

# Set to 1 to run `lms runtime update` on every container start.
LMS_RUNTIME_UPDATE=0

# =============================================================================
# HTTPS / Caddy
# =============================================================================

# Hostname Caddy will serve (must be in a Cloudflare-managed zone)
PROXY_HOST=

# Cloudflare API token — needs Zone:Read + DNS:Edit for the domain
# Create one at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Email used for Let's Encrypt account registration
ACME_EMAIL=

# =============================================================================
# API Authentication
# =============================================================================

# Bearer token clients must send in the Authorization header:
#   Authorization: Bearer <LLM_API_KEY>
# Generate a strong random value, e.g.:
#   openssl rand -hex 32
LLM_API_KEY=
